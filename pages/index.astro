---
import BaseLayout from "@/layouts/BaseLayout.astro";

const appOrigin = import.meta.env.PUBLIC_APP_ORIGIN || "https://app.nezumo.ru";
const signupUrl = `${appOrigin}/signup?lang=ru`;

const features = [
  {
    title: "♾️ Бесконечный холст",
    description: "Доски без границ",
    content:
      "Рисуйте, добавляйте фигуры, текст, изображения, PDF и видео на бесконечном холсте с плавным масштабированием.",
  },
  {
    title: "👥 Совместная работа",
    description: "В реальном времени",
    content:
      "Работайте над доской вместе с командой одновременно — изменения видны всем мгновенно.",
  },
  {
    title: "🗂️ Проекты и доски",
    description: "Всё под рукой",
    content:
      "Группируйте доски по проектам, отмечайте избранное и быстро возвращайтесь к недавним.",
  },
  {
    title: "🎤 Режим презентации",
    description: "Показывайте идеи",
    content:
      "Проводите презентации прямо с доски — без экспорта и переключения между приложениями.",
  },
];
---

<BaseLayout preloadHandwrittenFont>
  <!-- Hero -->
  <section class="px-4 pb-20 pt-24 sm:px-6 sm:pt-28 lg:px-8">
    <div class="container mx-auto text-center">
      <h1
        class="font-handwritten text-4xl sm:text-5xl lg:text-6xl tracking-tight mb-6"
      >
        Тут начинается то, чего ещё нет
      </h1>
      <p class="text-xl text-muted-foreground mb-8 max-w-3xl mx-auto">
        Бесконечный холст, где команда рисует, планирует и презентует вместе —
        в реальном времени.
      </p>
      <div class="flex justify-center">
        <a
          href={signupUrl}
          class="group inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-8 py-3.5 text-base font-semibold text-primary-foreground shadow-sm transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
        >
          Начать бесплатно
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            class="transition-transform group-hover:translate-x-0.5"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
      <div class="relative mx-auto mt-14 max-w-6xl">
        <div
          class="pointer-events-none absolute -inset-6 rounded-[2rem] bg-gradient-to-r from-violet-300/30 via-fuchsia-200/25 to-cyan-300/30 blur-3xl"
          aria-hidden="true"
        >
        </div>
        <div
          class="relative overflow-hidden rounded-[1.75rem] border border-white/80 bg-white/55 shadow-[0_30px_90px_-45px_rgba(57,38,93,0.65)] backdrop-blur"
        >
          <img
            src="/main_board.png"
            alt="Пример доски Nezumo с ретроспективой, материалами, медиа и заметками"
            width="1600"
            height="780"
            loading="eager"
            decoding="async"
            class="w-full"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold tracking-tight mb-4">
          Всё для совместной работы на одной доске
        </h2>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          Nezumo объединяет рисование, планирование и презентации в одном
          пространстве.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {
          features.map((feature) => (
            <article class="rounded-xl border bg-card text-card-foreground shadow-sm">
              <div class="flex flex-col space-y-1.5 p-6">
                <h3 class="font-semibold leading-none tracking-tight">
                  {feature.title}
                </h3>
                <p class="text-sm text-muted-foreground">
                  {feature.description}
                </p>
              </div>
              <div class="p-6 pt-0">
                <p class="text-sm text-muted-foreground">{feature.content}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl font-bold tracking-tight mb-4">Готовы начать?</h2>
      <p class="text-muted-foreground text-lg mb-8 max-w-2xl mx-auto">
        Создайте первую доску за пару минут и пригласите команду.
      </p>
      <div class="flex justify-center">
        <a
          href={signupUrl}
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-8 py-3.5 text-base font-semibold text-primary-foreground shadow-sm transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
        >
          Создать аккаунт
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
