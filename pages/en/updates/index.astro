---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const updates = (await getCollection("updates"))
  .filter((entry) => entry.id.startsWith("en/"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const dateFormatter = new Intl.DateTimeFormat("en-US", { day: "numeric", month: "long", year: "numeric" });
const changeLabels = {
  new: { label: "New", class: "bg-violet-100 text-violet-800" },
  improved: { label: "Improved", class: "bg-cyan-100 text-cyan-800" },
  fixed: { label: "Fixed", class: "bg-emerald-100 text-emerald-800" },
};
---

<BaseLayout lang="en" title="Updates — Nezumo" description="The Nezumo changelog: new features, interface improvements, and fixes.">
  <section class="relative overflow-hidden px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="pointer-events-none absolute left-1/2 top-4 h-72 w-72 -translate-x-1/2 rounded-full bg-violet-300/25 blur-3xl"></div>
    <div class="container relative mx-auto max-w-5xl">
      <header class="mx-auto mb-16 max-w-3xl text-center">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/70 bg-white/55 px-4 py-2 text-sm font-medium shadow-sm backdrop-blur">
          <span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-violet-400 opacity-60"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-violet-600"></span></span>
          Nezumo keeps getting better
        </span>
        <h1 class="mt-6 text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">Changelog</h1>
        <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-muted-foreground">New tools, meaningful improvements, and fixes — concise and useful.</p>
      </header>
      {updates.length === 0 && <p class="text-center text-muted-foreground">The first updates will appear here soon.</p>}
      <div class="relative">
        <div class="absolute bottom-0 left-[11px] top-3 w-px bg-gradient-to-b from-violet-400 via-border to-transparent sm:left-[132px]" aria-hidden="true"></div>
        <div class="space-y-12 sm:space-y-16">
          {updates.map((entry) => {
            const slug = entry.id.replace(/^en\//, "");
            return (
              <article class="relative grid gap-5 pl-10 sm:grid-cols-[108px_1fr] sm:gap-12 sm:pl-0">
                <div class="sm:text-right"><time datetime={entry.data.date.toISOString()} class="whitespace-nowrap text-sm font-medium text-muted-foreground">{dateFormatter.format(entry.data.date)}</time></div>
                <span class:list={["absolute left-0 top-0 flex h-6 w-6 items-center justify-center rounded-full border-4 border-[#faf8fc] shadow-sm sm:left-[121px]", entry.data.status === "planned" ? "bg-amber-400" : "bg-violet-600"]} aria-hidden="true"><span class="h-1.5 w-1.5 rounded-full bg-white"></span></span>
                <a href={`/en/updates/${slug}/`} class="group overflow-hidden rounded-3xl border border-white/80 bg-white/60 shadow-[0_22px_70px_-38px_rgba(57,38,93,0.5)] backdrop-blur-xl transition duration-300 hover:-translate-y-1 hover:bg-white/75">
                  {entry.data.cover && <div class="aspect-[16/8] overflow-hidden border-b border-white/80 bg-white/30"><img src={entry.data.cover} alt={entry.data.coverAlt || ""} loading="lazy" class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.015]" /></div>}
                  <div class="p-6 sm:p-8">
                    <div class="mb-4 flex flex-wrap items-center gap-2">
                      {entry.data.status === "planned" && <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-800">Coming soon</span>}
                      {Object.entries(entry.data.counts).map(([type, count]) => count > 0 && <span class={`rounded-full px-3 py-1 text-xs font-semibold ${changeLabels[type as keyof typeof changeLabels].class}`}>{changeLabels[type as keyof typeof changeLabels].label} · {count}</span>)}
                    </div>
                    <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">{entry.data.title}</h2>
                    {entry.data.summary && <p class="mt-3 text-base leading-relaxed text-muted-foreground sm:text-lg">{entry.data.summary}</p>}
                    {entry.data.highlights.length > 0 && <ul class="mt-6 grid gap-2 text-sm text-foreground/80 sm:grid-cols-2">{entry.data.highlights.slice(0, 4).map((highlight) => <li class="flex items-start gap-2"><span class="text-violet-600" aria-hidden="true">✓</span>{highlight}</li>)}</ul>}
                    <span class="mt-7 inline-flex items-center gap-2 text-sm font-semibold">Read more <span class="transition-transform group-hover:translate-x-1">→</span></span>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
