---
import BaseLayout from "@/layouts/BaseLayout.astro";

const appOrigin = import.meta.env.PUBLIC_APP_ORIGIN || "https://app.nezumo.ru";
const signupUrl = `${appOrigin}/signup`;

const features = [
  {
    title: "♾️ Infinite canvas",
    description: "Boards without boundaries",
    content: "Draw and add shapes, text, images, PDFs, and videos to an infinite canvas with smooth zooming.",
  },
  {
    title: "👥 Team collaboration",
    description: "In real time",
    content: "Work on a board with your team at the same time — everyone sees every change instantly.",
  },
  {
    title: "🗂️ Projects and boards",
    description: "Everything at hand",
    content: "Group boards into projects, mark favorites, and quickly return to your recent work.",
  },
  {
    title: "🎤 Presentation mode",
    description: "Share your ideas",
    content: "Present straight from your board — no exporting or switching between apps.",
  },
];
---

<BaseLayout lang="en" preloadHandwrittenFont>
  <section class="px-4 pb-20 pt-24 sm:px-6 sm:pt-28 lg:px-8">
    <div class="container mx-auto text-center">
      <h1 class="font-handwritten mb-6 text-4xl tracking-tight sm:text-5xl lg:text-6xl">
        This is where new ideas begin
      </h1>
      <p class="mx-auto mb-8 max-w-3xl text-xl text-muted-foreground">
        An infinite canvas where your team draws, plans, and presents together — in real time.
      </p>
      <div class="flex justify-center">
        <a href={signupUrl} class="group inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-8 py-3.5 text-base font-semibold text-primary-foreground shadow-sm transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2">
          Start for free
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">
            <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
      <div class="relative mx-auto mt-14 max-w-6xl">
        <div class="pointer-events-none absolute -inset-6 rounded-[2rem] bg-gradient-to-r from-violet-300/30 via-fuchsia-200/25 to-cyan-300/30 blur-3xl" aria-hidden="true"></div>
        <div class="relative overflow-hidden rounded-[1.75rem] border border-white/80 bg-white/55 shadow-[0_30px_90px_-45px_rgba(57,38,93,0.65)] backdrop-blur">
          <img src="/main_board.png" alt="A Nezumo board with a retrospective, resources, media, and notes" width="1600" height="780" loading="eager" decoding="async" class="w-full" />
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-20 sm:px-6 lg:px-8">
    <div class="container mx-auto">
      <div class="mb-16 text-center">
        <h2 class="mb-4 text-3xl font-bold tracking-tight">Everything your team needs on one board</h2>
        <p class="mx-auto max-w-2xl text-lg text-muted-foreground">
          Nezumo brings drawing, planning, and presenting together in one space.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
        {features.map((feature) => (
          <article class="rounded-xl border bg-card text-card-foreground shadow-sm">
            <div class="flex flex-col space-y-1.5 p-6">
              <h3 class="font-semibold leading-none tracking-tight">{feature.title}</h3>
              <p class="text-sm text-muted-foreground">{feature.description}</p>
            </div>
            <div class="p-6 pt-0"><p class="text-sm text-muted-foreground">{feature.content}</p></div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="px-4 py-20 sm:px-6 lg:px-8">
    <div class="container mx-auto text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">Ready to get started?</h2>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        Create your first board in minutes and invite your team.
      </p>
      <div class="flex justify-center">
        <a href={signupUrl} class="inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-8 py-3.5 text-base font-semibold text-primary-foreground shadow-sm transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2">
          Create an account
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
