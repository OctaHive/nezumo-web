---
export interface Props {
  lang?: "ru" | "en";
  mobile?: boolean;
}

const { lang = "ru", mobile = false } = Astro.props;
const label = lang === "en" ? "Open Nezumo on GitHub" : "Открыть Nezumo на GitHub";
---

<a
  href="https://github.com/OctaHive/nezumo"
  target="_blank"
  rel="noreferrer"
  aria-label={label}
  class:list={[
    "github-button inline-flex items-center justify-center gap-2 border border-zinc-300 bg-white/70 px-3 font-semibold text-zinc-950 shadow-sm backdrop-blur transition hover:-translate-y-0.5 hover:border-zinc-400 hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-violet-500 focus-visible:ring-offset-2",
    mobile ? "h-11 w-full rounded-xl" : "h-10 rounded-full",
  ]}
>
  <svg
    viewBox="0 0 24 24"
    class="h-[19px] w-[19px] shrink-0"
    fill="currentColor"
    aria-hidden="true"
  >
    <path d="M12 .7a11.5 11.5 0 0 0-3.64 22.41c.58.11.79-.25.79-.56v-2.23c-3.22.7-3.9-1.37-3.9-1.37-.52-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.57-.29-5.27-1.28-5.27-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.47.11-3.05 0 0 .97-.31 3.16 1.18A10.9 10.9 0 0 1 12 6.12c.98 0 1.95.13 2.86.38 2.2-1.49 3.16-1.18 3.16-1.18.63 1.58.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.41-2.71 5.38-5.29 5.67.42.36.79 1.06.79 2.14v3.28c0 .31.21.68.79.56A11.5 11.5 0 0 0 12 .7Z" />
  </svg>
  <span data-github-stars class="min-w-[1ch] text-sm tabular-nums">0</span>
  <span class="text-lg leading-none text-amber-400" aria-hidden="true">★</span>
</a>

<script>
  const elements = document.querySelectorAll<HTMLElement>("[data-github-stars]");
  const cacheKey = "nezumo-github-stars";
  const cacheLifetime = 15 * 60 * 1000;

  function updateStarCount(count: number) {
    const formatted = new Intl.NumberFormat("en-US").format(count);
    elements.forEach((element) => {
      element.textContent = formatted;
    });
  }

  try {
    const cached = JSON.parse(sessionStorage.getItem(cacheKey) || "null");
    if (
      cached &&
      typeof cached.count === "number" &&
      typeof cached.savedAt === "number" &&
      Date.now() - cached.savedAt < cacheLifetime
    ) {
      updateStarCount(cached.count);
    } else {
      fetch("https://api.github.com/repos/OctaHive/nezumo", {
        headers: { Accept: "application/vnd.github+json" },
      })
        .then((response) => {
          if (!response.ok) throw new Error("GitHub API request failed");
          return response.json();
        })
        .then((repository) => {
          if (typeof repository.stargazers_count !== "number") return;
          updateStarCount(repository.stargazers_count);
          sessionStorage.setItem(
            cacheKey,
            JSON.stringify({
              count: repository.stargazers_count,
              savedAt: Date.now(),
            }),
          );
        })
        .catch(() => {
          // Keep the static fallback when GitHub is unavailable.
        });
    }
  } catch {
    // Storage may be unavailable in privacy-focused browsing modes.
  }
</script>
